-- =========================
-- ابزارهای کمکی
-- =========================
local function safeGet(vals, idx)
    return vals and vals[idx] and vals[idx].value
end

local function clamp(v, min, max)
    if v < min then return min end
    if v > max then return max end
    return v
end

-- =========================
-- تابع‌های مدیریت بازه کاراکترها
-- =========================
local function initCharacterRanges()
    -- پاک کردن جداول قدیمی
    TYPE_AIM_HEIGHT = {[0] = 1.6}
    TYPE_NAMES = {[0] = "Unknown"}
    
    -- پر کردن جداول از بازه‌ها
    for _, range in ipairs(TYPE_RANGES) do
        for id = range.start, range.stop do
            TYPE_AIM_HEIGHT[id] = range.height
            TYPE_NAMES[id] = range.name
        end
    end
end

-- بارگذاری اولیه بازه‌ها
initCharacterRanges()

local function addCharacterRange(startID, endID, height, name)
    table.insert(TYPE_RANGES, {
        start = startID,
        stop = endID,
        height = height or 1.6,
        name = name or ("نوع " .. startID)
    })
    
    -- به‌روزرسانی جداول
    for id = startID, endID do
        TYPE_AIM_HEIGHT[id] = height or 1.6
        TYPE_NAMES[id] = name or ("نوع " .. startID)
    end
    
    gg.toast(string.format("✅ بازه %s (%d-%d) اضافه شد", name or startID, startID, endID))
    return true
end

local function removeCharacterRange(index)
    if index < 1 or index > #TYPE_RANGES then
        return false
    end
    
    local removed = table.remove(TYPE_RANGES, index)
    
    -- پاک کردن از جداول
    for id = removed.start, removed.stop do
        TYPE_AIM_HEIGHT[id] = nil
        TYPE_NAMES[id] = nil
    end
    
    -- مقداردهی مجدد به پیش‌فرض برای IDهای حذف شده
    for id = removed.start, removed.stop do
        TYPE_AIM_HEIGHT[id] = TYPE_AIM_HEIGHT[0] or 1.6
        TYPE_NAMES[id] = TYPE_NAMES[0] or "Unknown"
    end
    
    gg.toast("✅ بازه " .. removed.name .. " حذف شد")
    return true
end

-- =========================
-- تشخیص نوع کاراکتر
-- =========================
local function getCharacterType(charAddr)
    if not charAddr or charAddr == 0 then return 0 end
    local typePtr = safeGet(gg.getValues({{address = charAddr + OFF_TYPE_PTR, flags = gg.TYPE_QWORD}}), 1)
    if not typePtr or typePtr == 0 then return 0 end
    return safeGet(gg.getValues({{address = typePtr + OFF_TYPE_VAL, flags = gg.TYPE_DWORD}}), 1) or 0
end

local function getDistanceSqr(px, py, pz, ex, ey, ez)
    local dx = ex - px
    local dy = ey - py
    local dz = ez - pz
    return dx*dx + dy*dy + dz*dz
end

local function getAngularDistance(cy, cp, ty, tp)
    local yd = math.abs(ty - cy)
    if yd > 180 then yd = 360 - yd end
    local pd = math.abs(tp - cp)
    return math.sqrt(yd*yd + pd*pd)
end

-- =========================
-- محاسبات زاویه
-- =========================
local function calculateAngles(px, py, pz, ex, ey, ez, aimH)
    local dx = ex - px
    local dz = ez - pz
    local dy = (ey + aimH) - py

    if CONFIG.invertYaw then dx = -dx end

    local yaw = math.deg(math.atan2(dx, dz))
    if yaw < 0 then yaw = yaw + 360 end

    local horizontal = math.sqrt(dx*dx + dz*dz)
    if horizontal < 0.01 then horizontal = 0.01 end

    local pitch = math.deg(math.atan2(dy, horizontal))
    pitch = clamp(pitch, -89.9, 89.9)

    if CONFIG.invertPitch then pitch = -pitch end

    yaw = yaw + CONFIG.yawOffset
    pitch = pitch + CONFIG.pitchOffset

    return yaw, pitch
end

local function applySmoothing(cur, target, smooth)
    if smooth <= 0 then return target end
    local delta = target - cur
    -- کوتاه‌ترین چرخش برای yaw
    if math.abs(delta) > 180 then
        if delta > 0 then
            delta = delta - 360
        else
            delta = delta + 360
        end
    end
    return cur + delta * clamp(smooth, 0.0, 1.0)
end

local function applyHumanRandom(angle)
    if CONFIG.humanRandom <= 0 then return angle end
    local r = (math.random() * 2 - 1) * CONFIG.humanRandom
    return angle + r
end

local function getBoneAimHeight(enemy, baseY)
    local mode = enemy.boneMode or CONFIG.boneModeGlobal

    if mode == BONE_MODE.HEAD then
        return 1.8
    elseif mode == BONE_MODE.CHEST then
        return 1.2
    elseif mode == BONE_MODE.CUSTOM then
        return CONFIG.customAimHeight
    else
        return TYPE_AIM_HEIGHT[enemy.type] or 1.6
    end
end

local function getEffectiveFOV(dist)
    if not CONFIG.dynamicFOV then
        return CONFIG.fov
    end
    local d = math.sqrt(dist)
    local t = clamp(d / CONFIG.dynamicFOVDist, 0.0, 1.0)
    local fov = CONFIG.dynamicFOVMin + (CONFIG.dynamicFOVMax - CONFIG.dynamicFOVMin) * t
    return fov
end

-- =========================
-- سیستم Frame-Aligned Prediction
-- =========================
local function updateFrameTime()
    local currentTime = os.clock()
    
    if lastFrameTime > 0 then
        local delta = currentTime - lastFrameTime
        frameTimeSum = frameTimeSum + delta
        frameCount = frameCount + 1
        
        if frameCount >= 10 then  -- هر ۱۰ فریم میانگین بگیر
            avgFrameTime = frameTimeSum / frameCount
            frameTimeSum = 0
            frameCount = 0
            
            -- محدود کردن به بازه معقول
            avgFrameTime = clamp(avgFrameTime, 0.005, 0.1)  -- 5ms تا 100ms
        end
    end
    
    lastFrameTime = currentTime
    return avgFrameTime
end

local function getPredictionTime()
    if not CONFIG.autoPrediction then
        return CONFIG.predictionTime
    end
    
    -- محاسبه زمان پیش‌بینی بر اساس میانگین زمان فریم
    local frameTime = avgFrameTime
    
    -- زمان کل: زمان فریم + تأخیر نوشتن + حاشیه امنیت
    local totalDelay = frameTime * 2.0  -- دو فریم جلوتر
    
    -- محدود کردن به بازه مجاز
    return clamp(totalDelay, CONFIG.minPredictionTime, CONFIG.maxPredictionTime)
end

local function addPositionToHistory(addr, x, y, z)
    if not targetPosHistory[addr] then
        targetPosHistory[addr] = {}
    end
    
    local history = targetPosHistory[addr]
    
    -- اضافه کردن موقعیت جدید
    table.insert(history, 1, {
        x = x,
        y = y,
        z = z,
        time = os.clock()
    })
    
    -- حفظ اندازه تاریخچه
    while #history > POS_HISTORY_SIZE do
        table.remove(history)
    end
end

local function calculateVelocity(history)
    if not history or #history < 2 then
        return 0, 0, 0
    end
    
    local newest = history[1]
    local oldest = history[#history]
    
    local dt = newest.time - oldest.time
    if dt <= 0 then
        return 0, 0, 0
    end
    
    -- محاسبه سرعت (واحد در ثانیه)
    local vx = (newest.x - oldest.x) / dt
    local vy = (newest.y - oldest.y) / dt
    local vz = (newest.z - oldest.z) / dt
    
    -- اعمال smoothing برای جلوگیری از نوسان
    if CONFIG.velocitySmoothing > 0 then
        if history.avgVx then
            vx = history.avgVx * (1 - CONFIG.velocitySmoothing) + vx * CONFIG.velocitySmoothing
            vy = history.avgVy * (1 - CONFIG.velocitySmoothing) + vy * CONFIG.velocitySmoothing
            vz = history.avgVz * (1 - CONFIG.velocitySmoothing) + vz * CONFIG.velocitySmoothing
        end
        
        history.avgVx = vx
        history.avgVy = vy
        history.avgVz = vz
    end
    
    return vx, vy, vz
end

local function predictPosition(history, predictionTime)
    if not history or #history < 2 then
        return nil, nil, nil
    end
    
    local current = history[1]
    local vx, vy, vz = calculateVelocity(history)
    
    -- پیش‌بینی موقعیت آینده
    local predictedX = current.x + vx * predictionTime
    local predictedY = current.y + vy * predictionTime
    local predictedZ = current.z + vz * predictionTime
    
    return predictedX, predictedY, predictedZ
end

-- =========================
-- اسکن کاراکترها (با لاگ)
-- =========================
local function scanCharacters()
    writeLog("=== شروع اسکن کاراکترها ===")
    gg.clearResults()
    
    local searchValue = "0.82352942228"
    writeLog("🔎 جستجوی عدد: " .. searchValue .. " (TYPE_FLOAT)")
    gg.searchNumber(searchValue, gg.TYPE_FLOAT)
    
    local results = gg.getResults(5000)
    local resultCount = results and #results or 0
    logSearchResults("کاراکتر", searchValue, resultCount)
    
    if not results or #results == 0 then
        writeLog("❌ هیچ نتیجه‌ای پیدا نشد!")
        gg.alert("❌ ساختار کاراکتر پیدا نشد!")
        return false
    end

    -- لاگ اولین ۵ نتیجه
    for i = 1, math.min(5, #results) do
        local v = results[i]
        writeLog(string.format("  نتیجه %d: آدرس 0x%X | مقدار: %s", i, v.address, tostring(v.value)))
    end

    local validBases = {}
    for i = 1, #results do
        local v = results[i]
        local checkAddr = v.address + 16
        local checkVal = safeGet(gg.getValues({{address = checkAddr, flags = gg.TYPE_FLOAT}}), 1)
        
        writeLog(string.format("چک آدرس: 0x%X + 16 = 0x%X | مقدار: %s", 
            v.address, checkAddr, tostring(checkVal)))
        
        if checkVal and math.abs(checkVal - 0.53333336115) < 0.000001 then
            writeLog(string.format("✅ تطابق پیدا شد! آدرس: 0x%X", v.address))
            table.insert(validBases, v.address)
        end
    end

    writeLog("تعداد آدرس‌های معتبر: " .. #validBases)

    if #validBases == 0 then 
        writeLog("❌ هیچ آدرس معتبری پیدا نشد!")
        return false 
    end

    for i = 1, #validBases do
        local baseAddr = validBases[i]
        writeLog(string.format("--- پردازش Base %d: 0x%X ---", i, baseAddr))
        
        -- خواندن p1Val از آدرس +40
        local p1Val = safeGet(gg.getValues({{address = baseAddr + 40, flags = gg.TYPE_QWORD}}), 1)
        writeLog(string.format("p1Val (base+40=0x%X): 0x%X", baseAddr + 40, p1Val or 0))
        
        if not p1Val or p1Val < 0x7000000000 then 
            writeLog("❌ p1Val نامعتبر!")
            goto continue 
        end

        -- خواندن myCharAddr از p1Val + 136
        myCharAddr = safeGet(gg.getValues({{address = p1Val + 136, flags = gg.TYPE_QWORD}}), 1)
        writeLog(string.format("myCharAddr (p1+136=0x%X): 0x%X", p1Val + 136, myCharAddr or 0))

        -- خواندن p2Val از p1Val + 208
        local p2Val = safeGet(gg.getValues({{address = p1Val + 208, flags = gg.TYPE_QWORD}}), 1)
        writeLog(string.format("p2Val (p1+208=0x%X): 0x%X", p1Val + 208, p2Val or 0))
        
        if not p2Val or p2Val < 0x7000000000 then 
            writeLog("❌ p2Val نامعتبر!")
            goto continue 
        end

        -- خواندن p3Val از p2Val + 16
        local p3Val = safeGet(gg.getValues({{address = p2Val + 16, flags = gg.TYPE_QWORD}}), 1)
        writeLog(string.format("p3Val (p2+16=0x%X): 0x%X", p2Val + 16, p3Val or 0))
        
        if not p3Val or p3Val < 0x7000000000 then 
            writeLog("❌ p3Val نامعتبر!")
            goto continue 
        end

        local arrayBase = p3Val + 24
        writeLog(string.format("arrayBase (p3+24=0x%X): 0x%X", p3Val + 24, arrayBase))
        
        enemyAddrs = {}
        local enemyCount = 0

        for j = 0, 60 do
            local charPtrAddr = arrayBase + (j * 8)
            local charPtr = safeGet(gg.getValues({{address = charPtrAddr, flags = gg.TYPE_QWORD}}), 1)
            
            if not charPtr or charPtr == 0 then 
                writeLog(string.format("  [%d] آدرس: 0x%X | charPtr: 0 → پایان", j, charPtrAddr))
                break 
            end
            
            writeLog(string.format("  [%d] آدرس: 0x%X | charPtr: 0x%X", j, charPtrAddr, charPtr))
            
            if myCharAddr and charPtr == myCharAddr then 
                writeLog("  → این کاراکتر خودمان است، رد می‌شود")
                goto next 
            end

            local typeVal = getCharacterType(charPtr)
            local charName = TYPE_NAMES[typeVal] or ("نوع " .. typeVal)
            
            writeLog(string.format("  → دشمن: %s | نوع: %d | آدرس: 0x%X", charName, typeVal, charPtr))
            
            table.insert(enemyAddrs, {
                addr     = charPtr,
                type     = typeVal,
                name     = charName,
                enabled  = true,
                boneMode = BONE_MODE.AUTO,
            })
            enemyCount = enemyCount + 1

            ::next::
        end

        writeLog(string.format("تعداد دشمنان پیدا شده: %d", enemyCount))

        if myCharAddr and #enemyAddrs > 0 then
            writeLog("✅ اسکن موفق! " .. #enemyAddrs .. " دشمن پیدا شد")
            gg.toast("✅ " .. #enemyAddrs .. " دشمن پیدا شد (" .. #TYPE_RANGES .. " بازه فعال)")
            currentTarget = nil
            targetPosHistory = {}
            return true
        end

        ::continue::
    end

    writeLog("❌ اسکن ناموفق! هیچ دشمنی پیدا نشد.")
    return false
end


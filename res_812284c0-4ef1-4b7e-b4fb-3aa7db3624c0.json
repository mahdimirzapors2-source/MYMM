-- =========================
-- اسکن دوربین (با لاگ)
-- =========================
local function scanCamera()
    writeLog("=== شروع اسکن دوربین ===")
    gg.clearResults()
    
    local searchValue = "-80"
    writeLog("🔎 جستجوی عدد: " .. searchValue .. " (TYPE_FLOAT)")
    gg.searchNumber(searchValue, gg.TYPE_FLOAT)
    
    local results = gg.getResults(5000)
    local resultCount = results and #results or 0
    logSearchResults("دوربین", searchValue, resultCount)
    
    if not results or #results == 0 then 
        writeLog("❌ نتیجه‌ای برای دوربین پیدا نشد!")
        return false 
    end

    for i = 1, math.min(10, #results) do
        local v = results[i]
        writeLog(string.format("نتیجه %d: آدرس 0x%X | مقدار: %s", i, v.address, tostring(v.value)))
    end

    for i = 1, #results do
        local v = results[i]
        local base = v.address
        
        local check1 = safeGet(gg.getValues({{address = base + 28, flags = gg.TYPE_FLOAT}}), 1)
        writeLog(string.format("چک 1: 0x%X + 28 = 0x%X | مقدار: %s", base, base+28, tostring(check1)))
        
        if check1 and check1 == -80 then
            local check2 = safeGet(gg.getValues({{address = base + 36, flags = gg.TYPE_FLOAT}}), 1)
            writeLog(string.format("چک 2: 0x%X + 36 = 0x%X | مقدار: %s", base, base+36, tostring(check2)))
            
            if check2 and check2 == -80 then
                pitchAddr = base
                yawAddr = base - 4
                writeLog(string.format("✅ دوربین پیدا شد! Pitch: 0x%X, Yaw: 0x%X", pitchAddr, yawAddr))
                gg.toast("✅ آدرس دوربین پیدا شد")
                return true
            end
        end
    end
    
    writeLog("❌ دوربین پیدا نشد!")
    return false
end

-- =========================
-- انتخاب هدف با سیستم پیش‌بینی
-- =========================
local function selectBestTarget(px, py, pz, currentYaw, currentPitch)
    local bestYaw, bestPitch = nil, nil
    local bestScore = 1e18
    local bestIndex = nil
    local bestPredicted = false

    local maxCheck = math.min(#enemyAddrs, 30)

    for i = 1, maxCheck do
        local e = enemyAddrs[i]
        if not e or not e.enabled then goto continue end

        local evals = gg.getValues({
            {address = e.addr + OFF_X, flags = gg.TYPE_FLOAT},
            {address = e.addr + OFF_Y, flags = gg.TYPE_FLOAT},
            {address = e.addr + OFF_Z, flags = gg.TYPE_FLOAT},
        })
        
        local ex = evals[1].value or 0
        local ey = evals[2].value or 0
        local ez = evals[3].value or 0

        if ex == 0 and ey == 0 and ez == 0 then goto continue end
        
        -- ذخیره موقعیت در تاریخچه
        addPositionToHistory(e.addr, ex, ey, ez)

        -- انتخاب بین موقعیت فعلی یا پیش‌بینی شده
        local targetX, targetY, targetZ = ex, ey, ez
        local usingPrediction = false
        
        if CONFIG.predictionEnabled then
            local history = targetPosHistory[e.addr]
            local predictionTime = getPredictionTime()
            
            local predictedX, predictedY, predictedZ = predictPosition(history, predictionTime)
            if predictedX then
                targetX, targetY, targetZ = predictedX, predictedY, predictedZ
                usingPrediction = true
            end
        end

        local distSqr = getDistanceSqr(px, py, pz, targetX, targetY, targetZ)

        if distSqr < CONFIG.minDistance * CONFIG.minDistance or
           distSqr > CONFIG.maxDistance * CONFIG.maxDistance then
            goto continue
        end

        local aimH = getBoneAimHeight(e, targetY)
        local yaw, pitch = calculateAngles(px, py, pz, targetX, targetY, targetZ, aimH)

        local angleDist = getAngularDistance(currentYaw, currentPitch, yaw, pitch)
        local effectiveFOV = getEffectiveFOV(distSqr)

        if angleDist <= effectiveFOV then
            local score
            if CONFIG.priorityMode == TARGET_MODE.ANGLE then
                score = angleDist
            elseif CONFIG.priorityMode == TARGET_MODE.DIST then
                score = distSqr
            else -- HYBRID
                score = distSqr * 0.7 + angleDist * 0.3
            end
            
            -- اولویت به هدفی که از پیش‌بینی استفاده می‌کند
            if usingPrediction then
                score = score * 0.5  -- نمره بهتر
            end

            if score < bestScore then
                bestScore = score
                bestYaw = yaw
                bestPitch = pitch
                bestIndex = i
                bestPredicted = usingPrediction
            end
        end

        ::continue::
    end

    return bestYaw, bestPitch, bestIndex, bestPredicted
end

-- =========================
-- AIMBOT با سیستم Frame-Aligned
-- =========================
function aimbotLoop()
    -- به‌روزرسانی زمان فریم
    updateFrameTime()
    
    if not isAimbotActive or not myCharAddr or not yawAddr or not pitchAddr then return end
    
    -- بررسی دکمه شلیک
    local firePressed = false
    if fireToggleActive and fireButtonAddr then
        local fireState = safeGet(gg.getValues({{address = fireButtonAddr, flags = gg.TYPE_DWORD}}), 1)
        if fireState ~= nil then
            firePressed = (fireState == 0)
            lastFireState = fireState
        end
    else
        firePressed = true
    end
    
    if not firePressed then
        currentTarget = nil
        return
    end
    
    -- خواندن موقعیت خودمان و دوربین
    local vals = gg.getValues({
        {address = myCharAddr + OFF_X, flags = gg.TYPE_FLOAT},
        {address = myCharAddr + OFF_Y, flags = gg.TYPE_FLOAT},
        {address = myCharAddr + OFF_Z, flags = gg.TYPE_FLOAT},
        {address = yawAddr, flags = gg.TYPE_FLOAT},
        {address = pitchAddr, flags = gg.TYPE_FLOAT},
    })

    local px = vals[1].value or 0
    local py = vals[2].value or 0
    local pz = vals[3].value or 0
    local currentYaw = vals[4].value or 0
    local currentPitch = vals[5].value or 0
    
    -- انتخاب بهترین هدف
    local bestYaw, bestPitch, targetIndex, usingPrediction = 
        selectBestTarget(px, py, pz, currentYaw, currentPitch)
    
    if not bestYaw then 
        currentTarget = nil
        return 
    end
    
    -- ذخیره هدف فعلی
    local targetEnemy = enemyAddrs[targetIndex]
    currentTarget = {
        index = targetIndex,
        addr = targetEnemy.addr,
        name = targetEnemy.name,
        predicted = usingPrediction
    }

    -- اعمال smoothing
    local finalYaw   = applySmoothing(currentYaw, bestYaw, CONFIG.smooth)
    local finalPitch = applySmoothing(currentPitch, bestPitch, CONFIG.smooth)

    -- لرزش انسانی
    finalYaw   = applyHumanRandom(finalYaw)
    finalPitch = applyHumanRandom(finalPitch)

    -- نوشتن زوایا
    gg.setValues({
        {address = yawAddr, flags = gg.TYPE_FLOAT, value = finalYaw},
        {address = pitchAddr, flags = gg.TYPE_FLOAT, value = finalPitch},
    })

    -- نمایش دیباگ
    if CONFIG.showPredictionDebug then
        local debugMsg = "🎯 Target: " .. targetEnemy.name
        if usingPrediction then
            debugMsg = debugMsg .. " (Predicted)"
        end
        debugMsg = debugMsg .. "\nFrame: " .. string.format("%.1f", avgFrameTime * 1000) .. "ms"
        debugMsg = debugMsg .. "\nPredTime: " .. string.format("%.3f", getPredictionTime() * 1000) .. "ms"
        gg.toast(debugMsg, false)
    end
end

-- =========================
-- WallHack
-- =========================
local function applyWallHack()
    if not wallActive or #enemyAddrs == 0 then return end
    local t = {}
    for i = 1, #enemyAddrs do
        local e = enemyAddrs[i]
        t[#t+1] = {address = e.addr + 392, flags = gg.TYPE_DWORD, value = 0}
        t[#t+1] = {address = e.addr + 480, flags = gg.TYPE_DWORD, value = 65536}
    end
    gg.setValues(t)
end


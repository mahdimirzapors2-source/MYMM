        fireButtonAddr, myCharAddr, OFF_FIRE_BUTTON))
    
    local testVal = safeGet(gg.getValues({{address = fireButtonAddr, flags = gg.TYPE_DWORD}}), 1)
    writeLog(string.format("مقدار testVal: %s", tostring(testVal)))
    

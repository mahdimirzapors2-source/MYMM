-- =========================
-- سیستم لاگینگ (فقط لاگ، بدون تغییر)
-- =========================
local LOG_ENABLED = true
local logFile = "/sdcard/aimbot_log.txt"

local function writeLog(message)
    if not LOG_ENABLED then return end
    local file = io.open(logFile, "a+")
    if file then
        local timestamp = os.date("%Y-%m-%d %H:%M:%S")
        file:write(string.format("[%s] %s\n", timestamp, message))
        file:close()
    end
end

local function clearLog()
    local file = io.open(logFile, "w")
    if file then
        file:write("=== Aimbot Log Started ===\n")
        file:close()
    end
end

local function logSearchResults(searchType, searchValue, resultsCount)
    local msg = string.format("🔍 جستجو: %s | مقدار: %s | تعداد نتایج: %d", 
        searchType, tostring(searchValue), resultsCount or 0)
    writeLog(msg)
end

local function logFoundAddress(address, value, offset, description)
    local msg = string.format("📍 آدرس: 0x%X | مقدار: %s | آفست: %d | توضیح: %s", 
        address, tostring(value), offset or 0, description or "")
    writeLog(msg)
end

